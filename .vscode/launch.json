    "version": "0.2.0",
    "configurations": [
        {
            "type": "node-terminal",
            "name": "server",
            "request": "launch",
            "command": "node src/server.js",
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "node-terminal",
            "name": "worker",
            "request": "launch",
            "command": "node src/worker.js",
            "cwd": "${workspaceFolder}"
        }
    ],
    "compounds": [
        {
            "name": "Server & Worker",
            "configurations": [
                "server",
                "worker"
            ]
        }
    ]
}
